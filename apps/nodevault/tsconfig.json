{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable", "webworker"],
    "jsx": "preserve",
    "types": ["node", "react", "react-dom"],
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".open-next"
  ]
}
