{
  "name": "@nickchampion/platform",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "./.platform/build/build.sh",
    "db": "drizzle-kit migrate",
    "db:neon": "drizzle-kit migrate --config=drizzle.neon.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "compile": "tsc --noEmit",
    "lint": "nx run-many --target=lint --all --fix",
    "clean": "rm -rf apps/nodevault/.next apps/nodevault/.open-next apps/api/.output",
    "api": "reset && tsx watch --inspect=9228 ./apps/api/index.ts",
    "api:build": "nx reset && reset && nx build @platform/apps.api",
    "api:fly": "pnpm run api:build && cd apps/api && flyctl deploy -a nodevault",
    "app": "pnpm run clean && nx reset && reset && nx serve @platform/apps.nodevault",
    "app:build": "nx build @platform/apps.nodevault",
    "app:cf": "./.platform/cloudflare/local.sh",
    "inngest": "npx inngest-cli@latest dev -u http://api.nodevault.local:8002/api/inngest"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.52",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.12.1",
    "jsdom": "^29.1.1",
    "koa": "^3.2.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "next": "^15.5.20",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.17.2",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nx/esbuild": "^23.0.2",
    "@nx/eslint": "^23.0.2",
    "@nx/js": "^23.0.2",
    "@nx/vite": "^23.0.2",
    "@nx/web": "^23.0.2",
    "@nx/workspace": "^23.0.2",
    "@opennextjs/cloudflare": "^1.6.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/koa": "^3.0.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "constructs": "^10.6.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "happy-dom": "^20.10.6",
    "nx": "^23.0.2",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
